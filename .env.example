# Copy this file to .env and fill in local values.
# Do not put real secrets in files committed to Git.

GCP_PROJECT_ID=singapore-weather-mlops
GCP_REGION=asia-southeast1
BQ_LOCATION=asia-southeast1

BQ_RAW_DATASET=raw_layer
BQ_SILVER_DATASET=silver_layer
BQ_GOLD_DATASET=gold_layer
BQ_RAW_HISTORICAL_TABLE=historical
BQ_SILVER_TABLE=rain_silver
BQ_GOLD_VIEW=rain_gold

GCS_RAW_BUCKET=historical-rainfall-data
GCS_MODEL_BUCKET=historical-rainfall-data
GCS_HISTORICAL_URI=gs://historical-rainfall-data/HistoricalRainfallacrossSingapore*.csv
GCS_RAW_HISTORICAL_PREFIX=raw/historical/
GCS_RAW_REALTIME_PREFIX=raw/realtime/
GCS_MODEL_URI=gs://historical-rainfall-data/models/model.joblib

DATA_DIR=data
DATA_RAW_DIR=data/raw
DATA_INTERIM_DIR=data/interim
DATA_PROCESSED_DIR=data/processed
MODEL_DIR=models
SQL_DIR=sql
SCRIPTS_DIR=scripts

INGESTION_FUNCTION_NAME=ingest-rainfall
PREDICTION_FUNCTION_NAME=predict-rainfall

INGESTION_SCHEDULER_NAME=ingest-rainfall-every-5-min
PREDICTION_SCHEDULER_NAME=predict-rainfall-every-15-min

# Optional. Prefer gcloud auth application-default login.
GOOGLE_APPLICATION_CREDENTIALS=
